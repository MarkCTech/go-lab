# MySQL (used by Docker Compose and local tooling)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Dev-only default for Compose; use a strong password in any shared or production DB.
DB_PASS=toor
# MySQL database name (Compose sets MYSQL_DATABASE to this). Code default if unset: suite_platform
DB_NAME=suite_platform

API_PORT=5000
GIN_MODE=release

# JWT access tokens (HS256). Use a long random secret in production.
JWT_SECRET=change-me-to-at-least-32-chars-long!!
# Optional during rotation: previous secret still verifies. See docs/jwt-rotation.md
# JWT_SECRET_PREVIOUS=
# HS256 access-token iss/aud (distinct from OIDC_AUDIENCE when OIDC is enabled). See docs/oidc-auth0.md
JWT_ISSUER=suite-platform
JWT_AUDIENCE=suite-platform-api
JWT_ACCESS_TTL_SECONDS=900
# Short-lived user join tokens for Marble handoff (/api/v1/auth/join-token).
JOIN_TOKEN_TTL_SECONDS=120
# One-time desktop exchange-code TTL (/api/v1/auth/desktop/start -> /api/v1/auth/desktop/exchange).
DESKTOP_EXCHANGE_CODE_TTL_SECONDS=120
# Allowed callback hosts for desktop exchange start validation (loopback defaults).
DESKTOP_EXCHANGE_CALLBACK_HOSTS=localhost,127.0.0.1,::1

# Backend-only platform credentials for server token issuance (/api/v1/auth/token and /api/v1/auth/bootstrap).
# Rotate in production; never commit real .env.
PLATFORM_CLIENT_ID=dev-platform
PLATFORM_CLIENT_SECRET=change-me-dev-secret-min-length-16

# After `migrate up`, set to latest migration version so /readyz fails if DB is behind.
MIGRATION_EXPECTED_VERSION=8

# api/cmd/smoketest only (not read by the API). Comma-separated hosts allowed for -base (no port).
# Default if unset: localhost,127.0.0.1,::1. Use * to disable (not recommended). Smoketest mutates DB rows.
# SMOKETEST_ALLOW_HOSTS=localhost,127.0.0.1,::1

# Optional: OIDC / Auth0 RS256 access tokens (Bearer). Both empty = disabled; cookie + HS256 unchanged.
# OIDC_ISSUER_URL=https://YOUR_TENANT.auth0.com/
# OIDC_AUDIENCE=https://your-api-identifier

# Optional: Redis for shared per-IP rate limits + email login lockout across replicas. Unset = in-memory only.
# Redis errors at runtime fail open (see docs/auth-session.md). Docker: `docker compose --profile redis up -d`.
# REDIS_URL=redis://127.0.0.1:6379/0

# Browser session (POST /api/v1/auth/login). HttpOnly cookie; SPA never sees the token.
# For local HTTP (Compose), Secure must be false; behind HTTPS set true (see docs/tls-reverse-proxy.md).
SESSION_COOKIE_NAME=gl_session
SESSION_COOKIE_SECURE=false
SESSION_SAMESITE=Lax
SESSION_IDLE_TTL_SECONDS=1800
SESSION_ABSOLUTE_TTL_SECONDS=86400

# CSRF double-submit (non-HttpOnly cookie + matching header on cookie mutating requests). CORS allowlist includes CSRF_HEADER_NAME.
CSRF_COOKIE_NAME=gl_csrf
CSRF_HEADER_NAME=X-CSRF-Token

# Temporary SPA bridge (Origin allowlist). CI smoketest and local compose-smoke expect true; set false for prod-style deploys.
AUTH_BOOTSTRAP_ENABLED=true

# Optional: label current JWT signing key for future rotation logs (not yet used for verification).
# JWT_ACTIVE_KEY_ID=v1

# Comma-separated browser origins (no wildcard). Empty is not valid — default applied in code if unset.
CORS_ALLOWED_ORIGINS=http://localhost:4200
# Platform RBAC: grant platform roles in MySQL — see docs/platform-operator-roles.md
